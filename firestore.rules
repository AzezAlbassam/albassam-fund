rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Trades: anyone can read (family view link needs no login),
    // only the fund manager's verified Google account can write.
    match /trades/{tradeId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'azizbassam2018@gmail.com'
        && request.auth.token.email_verified == true;
    }
    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
